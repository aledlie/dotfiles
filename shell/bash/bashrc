# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/bashrc.pre.bash" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/bashrc.pre.bash"

# Bash configuration
# Set dotfiles directory
export DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

# Load common shell configuration
[[ -f "$DOTFILES_DIR/shell/common.sh" ]] && builtin source "$DOTFILES_DIR/shell/common.sh"

# Bash-specific settings
export HISTCONTROL=ignoredups:erasedups
shopt -s histappend        # append to history file, don't overwrite
shopt -s checkwinsize      # check window size after each command
shopt -s cdspell           # autocorrect typos in path names when using cd

# Enable color support of ls
if [ -x ~/.local/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
fi

command -v direnv >/dev/null 2>&1 && eval "$(direnv hook bash)"

# Python via pyenv
if command -v pyenv >/dev/null 2>&1; then
    _pyenv_init_cmd="$(pyenv init - bash)"
    # Avoid startup warnings when shims are not writable.
    if [[ -d "$PYENV_ROOT/shims" && ! -w "$PYENV_ROOT/shims" ]]; then
        _pyenv_init_cmd="$(printf '%s\n' "$_pyenv_init_cmd" | grep -v '^command pyenv rehash$')"
    fi
    eval "$_pyenv_init_cmd"
    unset _pyenv_init_cmd
fi

# Load custom prompt
[[ -f "$DOTFILES_DIR/shell/bash/prompt.bash" ]] && source "$DOTFILES_DIR/shell/bash/prompt.bash"

[ -f ~/.fzf.bash ] && source ~/.fzf.bash

# Kiro CLI post block. Keep at the bottom of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/bashrc.post.bash" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/bashrc.post.bash"
. "$HOME/.cargo/env"
